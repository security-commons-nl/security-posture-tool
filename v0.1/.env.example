# Microsoft Graph app-registration credentials
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# SQLite bestand — default is posture.sqlite in dezelfde folder
DB_PATH=posture.sqlite

# Drops-folder — waar de tool losse bestanden leest (CSV, logs, config-dumps).
# Default is ./drops/ naast app.py. Kan een absolute pad zijn, ook naar een
# gedeelde schijf.
DROPS_PATH=drops
